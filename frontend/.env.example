# Dalya frontend — environment variables
# Copy to .env.local for development; set the same keys in your deploy platform.

# ── Supabase (auth) ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
ADMIN_USER_ID=

# ── Contact / demo form email (Resend) ─────────────────────────
# Powers POST /api/contact, which emails demo requests.
# Setup:
#   1. Create a Resend account and verify the dalya.ae domain (add the
#      DNS records Resend gives you so SPF/DKIM pass).
#   2. Create an API key and paste it here / into the deploy env.
RESEND_API_KEY=
# Where demo requests are delivered (defaults to eric@dalya.ae if unset).
CONTACT_TO_EMAIL=eric@dalya.ae
# Verified sender the email comes from (must be on a Resend-verified domain).
CONTACT_FROM_EMAIL=Dalya Website <notifications@dalya.ae>
