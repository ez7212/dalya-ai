# Dalya API — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ── Required ──────────────────────────────────────────────────────────────────

# Anthropic API key for Claude (chatbot AI)
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Database ──────────────────────────────────────────────────────────────────

# PostgreSQL app-runtime connection string. Production/staging should use a
# least-privilege non-owner role here; schema migrations should use
# MIGRATION_DATABASE_URL / DATABASE_OWNER_URL instead.
# Get from: https://console.neon.tech → your project → Connection Details
DATABASE_URL=postgresql://username:password@ep-xxxxx.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require
# Schema-owner connection string for approved migration scripts only. Do not use
# this for the FastAPI app runtime.
MIGRATION_DATABASE_URL=
DATABASE_OWNER_URL=
# Non-secret production DB hostname used by test/rehearsal write guards to denylist production.
# Can be comma-separated if production has multiple hostnames.
PROD_DB_HOST=ep-production-xxxxx.us-east-1.aws.neon.tech

# ── Twilio (WhatsApp) ─────────────────────────────────────────────────────────

# Twilio credentials — get from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The WhatsApp number Twilio assigned (sandbox: +14155238886, production: your number)
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Your real phone number for the WhatsApp deep links (used in portal listings)
# Format: +971XXXXXXXXX
DALYA_PHONE_NUMBER=+971500000000

# ── Telegram (Escalation Alerts) ──────────────────────────────────────────────

# Telegram bot token — create bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=0000000000:XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Your personal Telegram chat ID — get from @userinfobot on Telegram
TELEGRAM_CHAT_ID=0000000000

# ── Server ────────────────────────────────────────────────────────────────────

# Public HTTPS URL of this server (used to register Telegram webhook at startup)
# Local dev: use ngrok — `ngrok http 8000` and paste the https URL.
# Production WhatsApp webhook verification fails closed when PUBLIC_URL is absent.
PUBLIC_URL=https://your-ngrok-or-domain.example.com

# ── DLD / RERA lookup ─────────────────────────────────────────────────────────

# Used to prefill agent onboarding from a RERA broker card number.
# Keep the consumer id configurable; do not assume one discovered in browser
# traffic is permanent or approved for production use.
DLD_CARD_SEARCH_URL=https://gateway.dubailand.gov.ae/card/office/search
DLD_GATEWAY_CONSUMER_ID=

# ── Supabase Auth ────────────────────────────────────────────────────────────

# Supabase project URL and anon key (used by the frontend)
SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# JWT secret for server-side token verification (Settings → API → JWT Secret)
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Admin user UUID (your Supabase auth user ID — used to gate admin-only endpoints)
ADMIN_USER_ID=00000000-0000-0000-0000-000000000000

# ── Environment ───────────────────────────────────────────────────────────────

# Production can be declared through DALYA_ENV, APP_ENV, or ENVIRONMENT.
# In production, debug/test routes are disabled, webhooks require configured
# verification secrets, and health output is redacted.
DALYA_ENV=development  # development | staging | production
ENVIRONMENT=development  # development | staging | production

# Local/dev test helpers. ENABLE_DEBUG_ROUTES defaults true outside production.
# Keep production debug routes off unless you are deliberately operating a
# locked-down internal deployment.
ENABLE_DEBUG_ROUTES=true
ENABLE_PRODUCTION_DEBUG_ROUTES=false
# Local/test/dev-only schema bootstrap. Ignored in production/staging/preview/live.
# Leave false for app-role RLS rehearsals and production-like deployments.
DALYA_ALLOW_RUNTIME_CREATE_ALL=0

# Shared secret required by /api/v1/leads/ingest/email in production.
LEAD_INGEST_SECRET=

# ── Background Workers / Cost Controls ───────────────────────────────────────

# Keep disabled in local/dev unless you are actively testing live WhatsApp flows.
# These workers query Postgres on an interval and can keep Neon compute warm.
ENABLE_DEBOUNCE_WORKER=false
ENABLE_SUMMARY_WORKER=false
ENABLE_RESEARCH_AUDITOR=false

# If live WhatsApp is enabled, 5 seconds is usually responsive enough and costs
# materially less than polling every second.
DEBOUNCE_SECONDS=5
DEBOUNCE_POLL_INTERVAL_SECONDS=5

# Conversation summaries are helpful for agents but do not need 5-minute polling
# at low volume.
SUMMARY_CHECK_INTERVAL_SECONDS=1800

# Community research auditing is maintenance work. Run weekly by default, or
# leave ENABLE_RESEARCH_AUDITOR=false and trigger manually when needed.
AUDIT_INTERVAL_SECONDS=604800

# ── Parser Settings ───────────────────────────────────────────────────────────

SPA_PARSE_DPI=150        # 150 = good quality, 200 = higher quality (more tokens)
MAX_FILE_SIZE_MB=20
NOC_THRESHOLD_DEFAULT=40  # % paid required for NOC — Emaar default

# Optional: RapidAPI provider for Bayut listing imports. Keep this secret out of git.
BAYUT_RAPIDAPI_KEY=

# ── Community Research ────────────────────────────────────
TAVILY_API_KEY=tvly-xxxxx           # Required for community research agent (web search). Get key at tavily.com
