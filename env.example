# Dalya API — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.

# Required
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Transcription (DAL-5)
TRANSCRIPTION_PROVIDER=speechmatics
TRANSCRIPTION_FALLBACK_PROVIDER=assemblyai
TRANSCRIPTION_CLAUDE_ENABLED=true
SPEECHMATICS_API_KEY=your_speechmatics_api_key_here
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here

# Database (Phase 2)
# App runtime DB URL. Production/staging should use a least-privilege non-owner role.
# DATABASE_URL=postgresql://app_user:password@localhost:5432/dalya
# Schema-owner URL for approved migration scripts only; never use for app runtime.
# MIGRATION_DATABASE_URL=postgresql://schema_owner:password@localhost:5432/dalya
# DATABASE_OWNER_URL=postgresql://schema_owner:password@localhost:5432/dalya
# Non-secret production DB hostname used to denylist production in test/rehearsal write guards.
# PROD_DB_HOST=ep-production-xxxxx.us-east-1.aws.neon.tech

# File Storage (Phase 2)
# SUPABASE_URL=your_supabase_url
# SUPABASE_KEY=your_supabase_anon_key
# SUPABASE_BUCKET=spa-documents

# Environment
DALYA_ENV=development  # development | staging | production
ENVIRONMENT=development  # development | staging | production

# Production ingress/security
PUBLIC_URL=https://your-ngrok-or-domain.example.com
MEDIA_URL_SIGNING_SECRET=replace_with_random_32_plus_byte_secret
MEDIA_URL_TTL_SECONDS=900
MEDIA_INBOUND_MAX_BYTES=10485760
# Local/test/rehearsal-only guard for scripts/media_lifecycle_dal171c1.py mutations.
DALYA_ALLOW_MEDIA_LIFECYCLE_MUTATION=0
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
LEAD_INGEST_SECRET=
ENABLE_DEBUG_ROUTES=true
ENABLE_PRODUCTION_DEBUG_ROUTES=false
# Local/test/dev-only schema bootstrap. Ignored in production/staging/preview/live.
DALYA_ALLOW_RUNTIME_CREATE_ALL=0

# Parser settings
SPA_PARSE_DPI=150        # 150 = good quality, 200 = higher quality (more tokens)
MAX_FILE_SIZE_MB=20
NOC_THRESHOLD_DEFAULT=40  # % paid required for NOC — Emaar default
